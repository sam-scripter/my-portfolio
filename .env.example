# ─────────────────────────────────────────────────────────────
# SAMUEL PORTFOLIO — Environment Variables Reference
# Copy relevant sections into each service's .env file
# NEVER commit actual .env files — this file only has placeholders
# ─────────────────────────────────────────────────────────────

# ── Shared / Infrastructure ───────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/samuel_portfolio
REDIS_URL=redis://127.0.0.1:6379

# ── backend-node (Fastify) ────────────────────────────────────
NODE_ENV=development
PORT=4000

# A long random string — protects the admin dashboard
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace_with_long_random_string_min_32_chars

# Internal URL of the Python RAG service — never exposed to browser
RAG_SERVICE_URL=http://localhost:8000

# GitHub personal access token (read-only scope is enough)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_USERNAME=Sam-scripter

# Rate limiting thresholds
RATE_LIMIT_PER_IP_DAILY=20
RATE_LIMIT_PER_SESSION=10
RATE_LIMIT_GLOBAL_DAILY=500

# ── backend-python (FastAPI RAG) ──────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# Models — these are the recommended defaults, change only if needed
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# How many knowledge chunks to inject into each AI prompt
MAX_CONTEXT_CHUNKS=5

# ── frontend (Next.js) ────────────────────────────────────────
# NEXT_PUBLIC_ prefix = exposed to the browser (safe for public data only)
NEXT_PUBLIC_API_URL=http://localhost:4000

# No NEXT_PUBLIC_ prefix = server-side only (never reaches the browser)
ADMIN_SECRET=965ecac698639e7a42581645b4c580d8545e8ab666f64187e8d66bcccb81f7f3